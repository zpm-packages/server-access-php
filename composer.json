{
  "name": "zpm-packages/server-access",
  "version": "1.0.0",
  "description": "Cross-platform PHP primitives for managing SSH-backed server access, users, keys, and permissions.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "ZPMPackages\\SshManager\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ZPMPackages\\SshManager\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit tests"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
